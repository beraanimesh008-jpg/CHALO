{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Store user and driver profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["USER", "DRIVER", "ADMIN"] },
        "phoneNumber": { "type": "string" },
        "rating": { "type": "number" },
        "totalRides": { "type": "number" },
        "isOnline": { "type": "boolean" },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "bikeDetails": {
          "type": "object",
          "properties": {
            "model": { "type": "string" },
            "number": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Information about a ride request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "pickup": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "drop": {
          "type": "object",
          "properties": {
            "address": { "type": "string" },
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "userOfferedFare": { "type": "number" },
        "status": { "type": "string", "enum": ["SEARCHING", "NEGOTIATING", "ACCEPTED", "ARRIVED", "IN_PROGRESS", "COMPLETED", "CANCELLED"] },
        "driverId": { "type": "string" },
        "acceptedFare": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "distance": { "type": "string" },
        "duration": { "type": "string" }
      },
      "required": ["userId", "pickup", "drop", "userOfferedFare", "status", "createdAt"]
    },
    "RideOffer": {
      "title": "Ride Offer",
      "description": "A fare offer from a driver for a ride",
      "type": "object",
      "properties": {
        "driverId": { "type": "string" },
        "driverName": { "type": "string" },
        "driverPhoto": { "type": "string" },
        "driverRating": { "type": "number" },
        "driverLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "offeredFare": { "type": "number" },
        "bikeDetails": {
          "type": "object",
          "properties": {
            "model": { "type": "string" },
            "number": { "type": "string" }
          }
        },
        "timestamp": { "type": "number" }
      },
      "required": ["driverId", "offeredFare", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride requests"
    },
    "/rides/{rideId}/offers/{driverId}": {
      "schema": "RideOffer",
      "description": "Fare offers from drivers"
    }
  }
}
